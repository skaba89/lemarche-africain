# ============================================================
# Le Marché Africain — Development Dockerfile
# Pour développement local avec hot-reload
# ============================================================

FROM node:20-alpine
WORKDIR /app

# Install bun
RUN npm install -g bun@latest

# Install dependencies for dev
COPY package.json bun.lockb* ./
RUN bun install

# Copy source
COPY . .

# Generate Prisma client
RUN bunx prisma generate

# Create database directory
RUN mkdir -p /app/db

EXPOSE 3000

ENV PORT=3000
ENV DATABASE_URL="file:/app/db/custom.db"

CMD ["bun", "run", "dev"]
